<Page
    x:Class="DJToolkitSetup.Views.SoulseekPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" Padding="40" MaxWidth="420">
        <TextBlock Text="Soulseek Credentials" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
        <TextBlock Text="Enter your Soulseek username and password. These are used by the embedded client to search and download music."
                   TextWrapping="Wrap" TextAlignment="Center" />

        <TextBlock Text="Username" />
        <TextBox x:Name="UsernameBox" PlaceholderText="Soulseek username" />

        <TextBlock Text="Password" />
        <PasswordBox x:Name="PasswordBox" PlaceholderText="Soulseek password" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
            <Button x:Name="BackButton" Content="Back" Click="BackButton_Click" />
            <Button x:Name="ContinueButton" Content="Continue" Style="{StaticResource AccentButtonStyle}"
                    Click="ContinueButton_Click" />
        </StackPanel>
    </StackPanel>
</Page>
