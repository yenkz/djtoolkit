<Page
    x:Class="DJToolkitSetup.Views.AcoustIDPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" Padding="40" MaxWidth="420">
        <TextBlock Text="AcoustID (Optional)" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
        <TextBlock Text="AcoustID is used for audio fingerprinting and duplicate detection. You can get a free API key at acoustid.org."
                   TextWrapping="Wrap" TextAlignment="Center" />

        <TextBlock Text="API Key" />
        <TextBox x:Name="AcoustidKeyBox" PlaceholderText="AcoustID API key (optional)" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
            <Button x:Name="BackButton" Content="Back" Click="BackButton_Click" />
            <Button x:Name="SkipButton" Content="Skip" Click="SkipButton_Click" />
            <Button x:Name="ContinueButton" Content="Continue" Style="{StaticResource AccentButtonStyle}"
                    Click="ContinueButton_Click" />
        </StackPanel>
    </StackPanel>
</Page>
