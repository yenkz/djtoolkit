<Page
    x:Class="DJToolkitSetup.Views.DonePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24" Padding="40">
        <FontIcon Glyph="&#xE73E;" FontSize="64" Foreground="Green" HorizontalAlignment="Center" />
        <TextBlock Text="Setup Complete" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
        <TextBlock Text="djtoolkit has been configured and the agent service is installed. You can now close this window."
                   TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="400" />
        <Button x:Name="CloseButton" Content="Close" HorizontalAlignment="Center"
                Style="{StaticResource AccentButtonStyle}" Click="CloseButton_Click" />
    </StackPanel>
</Page>
