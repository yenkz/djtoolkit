<Page
    x:Class="DJToolkitSetup.Views.SignInPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16" Padding="40" MaxWidth="420">
        <TextBlock Text="Sign In" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
        <TextBlock Text="Sign in with your browser to link this machine, or enter an API key manually."
                   TextWrapping="Wrap" TextAlignment="Center" />

        <Button x:Name="BrowserSignInButton" Content="Sign In with Browser"
                HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}"
                Click="BrowserSignInButton_Click" />

        <TextBlock Text="Or enter API key manually:" Margin="0,12,0,0" />
        <TextBox x:Name="ApiKeyBox" PlaceholderText="API key" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
            <Button x:Name="BackButton" Content="Back" Click="BackButton_Click" />
            <Button x:Name="ContinueButton" Content="Continue" Style="{StaticResource AccentButtonStyle}"
                    Click="ContinueButton_Click" />
        </StackPanel>

        <TextBlock x:Name="StatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
    </StackPanel>
</Page>
