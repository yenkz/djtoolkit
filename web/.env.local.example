# Next.js environment — copy to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# Supabase (public — baked into JS bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-side only — never exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DATABASE_URL=
SUPABASE_JWT_EC_X=
SUPABASE_JWT_EC_Y=
SUPABASE_JWT_AUDIENCE=authenticated

# Spotify OAuth (server-side only)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_CALLBACK_URL=http://localhost:3000/api/auth/spotify/callback
SPOTIFY_TOKEN_ENCRYPTION_KEY=
PLATFORM_FRONTEND_URL=http://localhost:3000

# Upstash Redis (server-side only — rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:push@djtoolkit.net

# djtoolkit API (Hetzner FastAPI service)
DJTOOLKIT_API_URL=
# Public — used by client for direct uploads (bypasses Vercel 4.5MB body limit)
NEXT_PUBLIC_DJTOOLKIT_API_URL=
