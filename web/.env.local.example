# Next.js environment — copy to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# Supabase project URL — https://<project-ref>.supabase.co
# Supabase dashboard → Settings → API → Project URL.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe to expose in the browser.
# Supabase dashboard → Settings → API → anon (public).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase publishable key (if using Supabase client-side SDK v2+)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# FastAPI backend URL (local dev: http://localhost:8000, prod: https://api.yourdomain.com)
NEXT_PUBLIC_API_URL=http://localhost:8000
