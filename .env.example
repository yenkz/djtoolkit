# djtoolkit secrets
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Soulseek account password (username goes in djtoolkit.toml [soulseek] section)
SOULSEEK_PASSWORD=

# AcoustID API key — optional, enables fingerprint → MusicBrainz lookup
# Get a free key at https://acoustid.org/login
ACOUSTID_API_KEY=

# Spotify API credentials — used for the 'spotify' cover art source (Client Credentials flow)
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Last.fm API key — optional, for the 'lastfm' cover art source
# Get a free key at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ─── Supabase (cloud platform) ────────────────────────────────────────────────
# Supabase dashboard → Settings → Database / API for all values below.
#
# DB connection for asyncpg pool (FastAPI + tests).
# Use the Supavisor SESSION MODE URL (port 5432) — NOT the direct host (db.*) or transaction pooler (port 6543).
# Supabase dashboard → Settings → Database → Connection pooling → Session mode.
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
SUPABASE_DATABASE_URL=

# Project URL — https://<project-ref>.supabase.co
# Supabase dashboard → Settings → API → Project URL.
SUPABASE_PROJECT_URL=

# JWT EC public key — used by API middleware to verify Supabase Auth ES256 tokens.
# Fetch from: GET https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# Copy the "x" and "y" values from the first key in the "keys" array.
SUPABASE_JWT_EC_X=
SUPABASE_JWT_EC_Y=
# JWT audience claim — Supabase Auth sets this to "authenticated" for logged-in users.
SUPABASE_JWT_AUDIENCE=authenticated

# Service-role key — used for user table writes and admin operations (bypasses RLS).
# Supabase dashboard → Settings → API → service_role (secret). Keep this secret.
SUPABASE_SERVICE_ROLE_KEY=

# Your Supabase Auth user UUID — required for CLI commands that read/write tracks.
# Find it at djtoolkit.net/settings or in the Supabase Auth dashboard.
DJTOOLKIT_USER_ID=

# Anon (public) key — used by the web UI / client-side Supabase calls.
# Supabase dashboard → Settings → API → anon (public). Safe to expose in browser.
SUPABASE_ANON_KEY=

# Fernet encryption key for Spotify OAuth tokens stored in DB.
# Generate once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SPOTIFY_TOKEN_ENCRYPTION_KEY=
