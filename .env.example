# djtoolkit secrets
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# slskd API key — only needed if slskd auth is enabled in its config
SLSKD_API_KEY=

# AcoustID API key — optional, enables fingerprint → MusicBrainz lookup
# Get a free key at https://acoustid.org/login
ACOUSTID_API_KEY=

# Spotify API credentials — used for the 'spotify' cover art source (Client Credentials flow)
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Last.fm API key — optional, for the 'lastfm' cover art source
# Get a free key at https://www.last.fm/api/account/create
LASTFM_API_KEY=
