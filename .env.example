# djtoolkit secrets
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# slskd API key — only needed if slskd auth is enabled in its config
SLSKD_API_KEY=

# AcoustID API key — optional, enables fingerprint → MusicBrainz lookup
# Get a free key at https://acoustid.org/login
ACOUSTID_API_KEY=
