# djtoolkit secrets
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Soulseek account password (username goes in djtoolkit.toml [soulseek] section)
SOULSEEK_PASSWORD=

# AcoustID API key — optional, enables fingerprint → MusicBrainz lookup
# Get a free key at https://acoustid.org/login
ACOUSTID_API_KEY=

# Spotify API credentials — used for the 'spotify' cover art source (Client Credentials flow)
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Last.fm API key — optional, for the 'lastfm' cover art source
# Get a free key at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ─── Supabase (cloud platform) ────────────────────────────────────────────────
# Project: wpjrzpsfssyzjgfzcmvf  |  https://supabase.com/dashboard/project/wpjrzpsfssyzjgfzcmvf
#
# DB connection for asyncpg pool (FastAPI + tests).
# Use the Supavisor SESSION MODE URL (port 5432) — NOT the direct host (db.*) or transaction pooler (port 6543).
# Supabase dashboard → Settings → Database → Connection pooling → Session mode.
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
SUPABASE_DATABASE_URL=postgresql://postgres.wpjrzpsfssyzjgfzcmvf:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# JWT secret — used by API middleware to verify Supabase Auth tokens.
# Supabase dashboard → Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=

# Service-role key — used for user table writes and admin operations (bypasses RLS).
# Supabase dashboard → Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=

# Anon (public) key — used by the web UI / client-side Supabase calls.
# Supabase dashboard → Settings → API → anon (public).
SUPABASE_ANON_KEY=
